generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Feedback {
  id        String   @id @default(uuid())
  type      String   @default("suggestion")
  content   String
  contact   String?
  page      String?
  createdAt DateTime @default(now()) @map("created_at")
  read      Boolean  @default(false)

  @@map("feedbacks")
}
